  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ddcdd4937e03046d2bdf865f4b6d9443, type: 3}
  m_Name: Dialogue_PoliceStop
  m_EditorClassIdentifier: Reloader.NPCs::Reloader.NPCs.Data.DialogueDefinition
  _dialogueId: dialogue.police.stop
  _entryNodeId: entry
  _nodes:
  - _nodeId: entry
    _speakerText: Stop right there. Keep your hands where I can see them.
    _replies:
    - _replyId: reply.police.comply
      _replyText: Easy. I am not looking for trouble.
      _nextNodeId:
      _outcomeActionId: police.stop.comply
      _outcomePayload: comply
    - _replyId: reply.police.question
      _replyText: What is this about, officer?
      _nextNodeId:
      _outcomeActionId: police.stop.question
      _outcomePayload: question
    - _replyId: reply.police.leave
      _replyText: I am leaving.
      _nextNodeId:
      _outcomeActionId: police.stop.leave
      _outcomePayload: leave
