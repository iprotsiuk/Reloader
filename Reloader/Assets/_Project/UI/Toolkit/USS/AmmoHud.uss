.ammo-hud {
    padding-top: 4px;
    padding-right: 8px;
    padding-bottom: 4px;
    padding-left: 8px;
    background-color: rgba(0, 0, 0, 0.55);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
}

.ammo-hud__label {
    color: rgba(255, 255, 255, 0.95);
    font-size: 16px;
}
