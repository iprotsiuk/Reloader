@import url("UiKit.uss");

.compass-hud__screen {
    position: absolute;
    left: 0;
    right: 0;
    top: 12px;
    flex-direction: column;
    align-items: center;
}

.compass-hud {
    width: 280px;
    padding-top: 4px;
    padding-right: 10px;
    padding-bottom: 4px;
    padding-left: 10px;
    background-color: rgba(16, 18, 21, 0.58);
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
}

.compass-hud__frame {
    position: relative;
    width: 100%;
    height: 21px;
}

.compass-hud__lane {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
}

.compass-hud__entries {
    position: relative;
    width: 100%;
    height: 100%;
}

.compass-hud__entry {
    position: absolute;
    top: 50%;
    translate: -50% -50%;
}

.compass-hud__entry--cardinal {
    color: rgba(239, 243, 249, 0.9);
    font-size: 14px;
    -unity-font-style: bold;
}

.compass-hud__entry--marker {
    min-width: 10px;
    height: 12px;
    padding-top: 1px;
    padding-right: 3px;
    padding-bottom: 1px;
    padding-left: 3px;
    background-color: rgba(233, 195, 87, 0.16);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgba(233, 195, 87, 0.72);
    border-right-color: rgba(233, 195, 87, 0.72);
    border-bottom-color: rgba(233, 195, 87, 0.72);
    border-left-color: rgba(233, 195, 87, 0.72);
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    border-bottom-left-radius: 6px;
}

.compass-hud__entry-marker-label {
    color: rgba(244, 224, 150, 0.95);
    font-size: 8px;
    unity-text-align: middle-center;
}

.compass-hud__center-tick {
    position: absolute;
    left: 50%;
    top: 2px;
    bottom: 2px;
    width: 2px;
    translate: -50% 0;
    background-color: rgba(255, 255, 255, 0.58);
}
