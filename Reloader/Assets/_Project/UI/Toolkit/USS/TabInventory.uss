.inventory__panel {
    flex-direction: column;
    gap: 6px;
}

.inventory__slot {
    width: 52px;
    height: 52px;
    background-color: rgba(255, 255, 255, 0.06);
}

.inventory__slot.is-occupied {
    background-color: rgba(255, 255, 255, 0.18);
}

.inventory__tooltip {
    padding-top: 4px;
    padding-right: 6px;
    padding-bottom: 4px;
    padding-left: 6px;
    background-color: rgba(0, 0, 0, 0.72);
}
